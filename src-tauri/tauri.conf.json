{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsApped",
  "version": "0.1.4",
  "identifier": "com.naeru.whatsapped",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WhatsApped",
        "width": 1200,
        "height": 800,
        "url": "https://web.whatsapp.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "whatsapp",
          "wapped"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}