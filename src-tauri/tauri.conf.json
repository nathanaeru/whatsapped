{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whatsapped",
  "version": "0.1.1",
  "identifier": "com.naeru.whatsapped",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WhatsApp",
        "width": 1200,
        "height": 800,
        "url": "https://web.whatsapp.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
